# 複製成 .env.local 後填入 Firebase Console → Project settings → Your apps → Web 的 firebaseConfig
# Copy to .env.local, then paste values from Firebase Web app config
#
#   Windows PowerShell:  Copy-Item .env.example .env.local
#   macOS / Linux:       cp .env.example .env.local
#
# .env.local 已被 gitignore，不要 commit 真實值
# .env.local is gitignored — do not commit real values
#
# 改完後必須重啟 Vite（npm run dev），環境變數才會生效
# Restart Vite after editing so env vars reload

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# LINE Identity Platform OIDC（Console 名稱 LINE → 通常 oidc.line）
# VITE_FIREBASE_LINE_PROVIDER_ID=oidc.line

# 複製成 .env 後再改密碼（.env 不要 commit）
# Copy to .env, then change the password (.env must NOT be committed)
#
#   Windows PowerShell:  Copy-Item .env.example .env
#   macOS / Linux:       cp .env.example .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=請改成你的本機開發密碼
POSTGRES_DB=yuruicamp
POSTGRES_PORT=5433

# Spring Boot（backend/）可選覆寫；預設連 localhost:5433
# DB_URL=jdbc:postgresql://localhost:5433/yuruicamp
# DB_USERNAME=postgres
# DB_PASSWORD=（與上面 POSTGRES_PASSWORD 相同）

# Firebase：預設 false 時使用 dev: stub token（見 backend/README.md）
# FIREBASE_ENABLED=false
# FIREBASE_CREDENTIALS=C:\path\to\firebase-service-account.json

# ECPay AIO Sandbox（正式環境請改用正式特店資訊）
# ECPAY_MERCHANT_ID=3002607

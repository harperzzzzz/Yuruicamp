<main class="memberCenter" id="memberCenterComponentRoot" data-component="member-center">
  <section class="memberLoginGuard" id="memberLoginGuard" role="status" aria-live="polite">
    <div class="memberLoginGuardCard">
      <div class="memberLoginGuardIcon" aria-hidden="true"><i class="bi bi-person-lock"></i></div>
      <h1 class="memberLoginGuardTitle">需要登入會員</h1>
      <p class="memberLoginGuardText">登入後即可查看會員資料、訂單紀錄、租借紀錄、折價券與通知。</p>
      <button class="memberAction memberActionPrimary" id="guardLoginBtn" type="button">
        <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
        會員登入
      </button>
      <a href="home.html" class="memberAction memberActionOutline" data-member-center-home-link>返回首頁</a>
    </div>
  </section>

  <div class="memberCenterShell" id="memberCenterShell" hidden>
    <nav class="memberMobileNavigation" aria-label="會員中心行動導覽">
      <button class="memberMobileNavItem isActive" type="button" data-tab="overview" aria-controls="memberPanelOverview" aria-selected="true"><i class="bi bi-house" aria-hidden="true"></i>總覽</button>
      <button class="memberMobileNavItem" type="button" data-tab="profile" aria-controls="memberPanelProfile" aria-selected="false"><i class="bi bi-person" aria-hidden="true"></i>資料</button>
      <button class="memberMobileNavItem" type="button" data-tab="records" aria-controls="memberPanelRecords" aria-selected="false"><i class="bi bi-receipt" aria-hidden="true"></i>紀錄</button>
      <button class="memberMobileNavItem" type="button" data-tab="coupons" aria-controls="memberPanelCoupons" aria-selected="false"><i class="bi bi-ticket-perforated" aria-hidden="true"></i>折價券</button>
      <button class="memberMobileNavItem" type="button" data-tab="notifications" aria-controls="memberPanelNotifications" aria-selected="false"><i class="bi bi-bell" aria-hidden="true"></i>通知</button>
    </nav>

    <div class="memberCenterLayout">
      <aside class="memberSidebar" aria-label="會員資料與導覽">
        <div class="memberProfileSummary">
          <div class="memberAvatar" id="mcAvatar" aria-hidden="true">Y</div>
          <div class="memberProfileText">
            <div class="memberProfileName" id="mcName">會員</div>
            <div class="memberProfileEmail" id="mcEmail">loading...</div>
          </div>
        </div>
        <nav class="memberNavigation" aria-label="會員中心導覽">
          <button class="memberNavItem isActive" type="button" data-tab="overview" aria-current="page" aria-controls="memberPanelOverview" aria-selected="true"><i class="bi bi-house" aria-hidden="true"></i><span class="memberNavLabel">總覽</span></button>
          <button class="memberNavItem" type="button" data-tab="profile" aria-controls="memberPanelProfile" aria-selected="false"><i class="bi bi-person" aria-hidden="true"></i><span class="memberNavLabel">會員資料</span></button>
          <button class="memberNavItem" type="button" data-tab="records" aria-controls="memberPanelRecords" aria-selected="false"><i class="bi bi-receipt" aria-hidden="true"></i><span class="memberNavLabel">訂單紀錄</span></button>
          <button class="memberNavItem" type="button" data-tab="coupons" aria-controls="memberPanelCoupons" aria-selected="false"><i class="bi bi-ticket-perforated" aria-hidden="true"></i><span class="memberNavLabel">折價券</span></button>
          <button class="memberNavItem" type="button" data-tab="notifications" aria-controls="memberPanelNotifications" aria-selected="false"><i class="bi bi-bell" aria-hidden="true"></i><span class="memberNavLabel">通知中心</span></button>
        </nav>
      </aside>

      <div class="memberContent">
        <section class="memberPanel isActive" id="memberPanelOverview" data-panel="overview" aria-labelledby="memberPanelOverviewTitle">
          <div class="memberPanelHeader">
            <h2 class="memberPanelTitle" id="memberPanelOverviewTitle">會員總覽</h2>
            <p class="memberPanelDescription">快速查看點數、待處理事項與最近活動。</p>
          </div>
          <section class="memberTierCard" aria-labelledby="memberTierTitle">
            <div class="memberTierHeader"><span class="memberTierBrand">Yuruicamp</span><span class="memberTierName" id="cardTier">Explorer</span></div>
            <h3 class="memberTierMemberName" id="cardName">露友</h3>
            <p class="memberTierMeta" id="cardSince">加入日期：--</p>
            <p class="memberTierPoints" id="cardPoints">回饋點數：載入中</p>
            <p class="memberTierProgressLabel" id="memberTierTitle">距離下個等級還需 <strong id="nextTierSpend">NT$ 0</strong></p>
            <div class="memberTierProgress" aria-hidden="true"><div class="memberTierProgressBar" id="tierProgressBar"></div></div>
          </section>
          <div class="memberStats" aria-label="會員統計">
            <article class="memberStatCard"><div class="memberStatValue" id="statOrders">0</div><div class="memberStatLabel">待處理訂單</div></article>
            <article class="memberStatCard"><div class="memberStatValue" id="statBookings">0</div><div class="memberStatLabel">預約租借</div></article>
            <article class="memberStatCard"><div class="memberStatValue" id="statCoupons">0</div><div class="memberStatLabel">可用折價券</div></article>
            <article class="memberStatCard"><div class="memberStatValue isError" id="statUnread">0</div><div class="memberStatLabel">未讀通知</div></article>
          </div>
          <section class="memberPanelSection" aria-labelledby="recentActivityTitle">
            <h3 class="memberPanelSectionTitle" id="recentActivityTitle"><i class="bi bi-clock-history" aria-hidden="true"></i>最近活動</h3>
            <div id="recentActivity"><div class="memberLoadingState">載入最近活動中...</div></div>
          </section>
        </section>

        <section class="memberPanel" id="memberPanelProfile" data-panel="profile" aria-labelledby="memberPanelProfileTitle" hidden>
          <div class="memberPanelHeader"><h2 class="memberPanelTitle" id="memberPanelProfileTitle">會員資料</h2><p class="memberPanelDescription">更新聯絡資訊與個人露營偏好。</p></div>
          <section class="memberPanelSection">
            <form class="memberProfileForm" id="profileForm" novalidate>
              <div class="memberFormGroup"><label class="memberFormLabel" for="profileName">姓名</label><input class="memberFormInput" type="text" id="profileName" name="name" placeholder="請輸入姓名" /></div>
              <div class="memberFormGroup"><label class="memberFormLabel" for="profilePhone">電話</label><input class="memberFormInput" type="tel" id="profilePhone" name="phone" placeholder="0912-345-678" /></div>
              <div class="memberFormGroup"><label class="memberFormLabel" for="profileEmail">電子郵件</label><input class="memberFormInput" type="email" id="profileEmail" name="email" placeholder="your@email.com" readonly aria-readonly="true" /></div>
              <div class="memberFormGroup"><label class="memberFormLabel" for="profileBirthday">生日</label><input class="memberFormInput" type="date" id="profileBirthday" name="birthday" readonly aria-readonly="true" /></div>
              <div class="memberFormGroup memberFormGroupFull"><label class="memberFormLabel" for="profileAddress">配送地址</label><input class="memberFormInput" type="text" id="profileAddress" name="address" placeholder="請輸入常用配送地址" /></div>
              <fieldset class="memberFormGroup memberFormGroupFull"><legend class="memberFormLabel">露營偏好</legend><div class="memberPreferenceList" id="prefTags">
                <button class="memberPreferenceTag" type="button" data-value="glamping">Glamping</button><button class="memberPreferenceTag" type="button" data-value="backpacking">背包旅行</button><button class="memberPreferenceTag" type="button" data-value="family">家庭露營</button><button class="memberPreferenceTag" type="button" data-value="solo">獨旅</button><button class="memberPreferenceTag" type="button" data-value="hiking">登山健行</button><button class="memberPreferenceTag" type="button" data-value="car-camping">車宿</button><button class="memberPreferenceTag" type="button" data-value="ultralight">輕量化</button><button class="memberPreferenceTag" type="button" data-value="base-camp">基地營</button><button class="memberPreferenceTag" type="button" data-value="tent">帳篷</button><button class="memberPreferenceTag" type="button" data-value="sleeping-bag">睡袋</button><button class="memberPreferenceTag" type="button" data-value="backpack">背包</button><button class="memberPreferenceTag" type="button" data-value="cooking">炊具</button><button class="memberPreferenceTag" type="button" data-value="lighting">照明</button><button class="memberPreferenceTag" type="button" data-value="clothing">服飾</button><button class="memberPreferenceTag" type="button" data-value="chair">椅凳</button><button class="memberPreferenceTag" type="button" data-value="navigation">導航</button><button class="memberPreferenceTag" type="button" data-value="safety">安全用品</button><button class="memberPreferenceTag" type="button" data-value="photography">攝影</button>
              </div></fieldset>
              <div class="memberFormActions"><button type="submit" class="memberAction memberActionPrimary"><i class="bi bi-floppy" aria-hidden="true"></i>儲存資料</button></div>
            </form>
          </section>
        </section>

        <section class="memberPanel" id="memberPanelRecords" data-panel="records" aria-labelledby="memberPanelRecordsTitle" hidden>
          <div class="memberPanelHeader"><h2 class="memberPanelTitle" id="memberPanelRecordsTitle">訂單紀錄</h2><p class="memberPanelDescription">查看購買訂單、預約與租借狀態。</p></div>
          <section class="memberPanelSection">
            <div class="memberRecordTabs" role="tablist" aria-label="紀錄類型"><button class="memberRecordTab isActive" type="button" data-rec="purchase" aria-selected="true" aria-controls="purchaseOrdersPanel">購買紀錄</button><button class="memberRecordTab" type="button" data-rec="rental" aria-selected="false" aria-controls="rentalOrdersPanel">預約與租借</button></div>
            <div class="memberRecordPanel isActive" id="purchaseOrdersPanel" data-rec-panel="purchase" data-order-panel="purchase"><div class="memberOrderFilters" id="purchaseOrderStatusTabs" data-order-status-tabs="purchase"></div><div class="memberOrderList" id="ordersList"><div class="memberLoadingState">載入購買紀錄中...</div></div></div>
            <div class="memberRecordPanel" id="rentalOrdersPanel" data-rec-panel="rental" data-order-panel="rental" hidden><div class="memberOrderFilters" id="rentalOrderStatusTabs" data-order-status-tabs="rental"></div><div class="memberOrderList" id="rentalOrdersList"><div class="memberLoadingState">載入租借紀錄中...</div></div></div>
          </section>
        </section>

        <section class="memberPanel" id="memberPanelCoupons" data-panel="coupons" aria-labelledby="memberPanelCouponsTitle" hidden>
          <div class="memberPanelHeader"><h2 class="memberPanelTitle" id="memberPanelCouponsTitle">折價券</h2><p class="memberPanelDescription">管理可使用與已失效的會員折價券。</p></div>
          <section class="memberPanelSection"><div class="memberRecordTabs" role="tablist" aria-label="折價券狀態"><button class="memberRecordTab isActive" type="button" data-coupon-tab="available" aria-selected="true" aria-controls="activeCoupons">可使用</button><button class="memberRecordTab" type="button" data-coupon-tab="unavailable" aria-selected="false" aria-controls="expiredCoupons">已失效</button></div><div class="memberCouponList" id="activeCoupons"></div><div class="memberCouponList" id="expiredCoupons" hidden></div></section>
        </section>

        <section class="memberPanel" id="memberPanelNotifications" data-panel="notifications" aria-labelledby="memberPanelNotificationsTitle" hidden>
          <div class="memberPanelHeader"><div><h2 class="memberPanelTitle" id="memberPanelNotificationsTitle">通知中心</h2><p class="memberPanelDescription">查看訂單與活動通知。</p></div><button class="memberAction memberActionOutline" id="markAllReadBtn" type="button">全部標示已讀</button></div>
          <section class="memberPanelSection"><div class="memberNotificationList" id="notificationList"><div class="memberLoadingState">載入通知中...</div></div></section>
        </section>
      </div>
    </div>
  </div>

  <div class="memberModalOverlay" id="orderDetailOverlay" aria-hidden="true"><section class="memberModalDialog" role="dialog" aria-modal="true" aria-labelledby="orderDetailTitle" tabindex="-1"><header class="memberModalHeader"><h2 class="memberModalTitle" id="orderDetailTitle">訂單明細</h2><button class="memberModalClose" id="orderDetailClose" type="button" aria-label="關閉">&times;</button></header><div class="memberModalBody" id="orderDetailBody"></div></section></div>
  <div class="memberModalOverlay" id="reviewOverlay" aria-hidden="true"><section class="memberModalDialog" role="dialog" aria-modal="true" aria-labelledby="reviewTitle" tabindex="-1"><header class="memberModalHeader"><h2 class="memberModalTitle" id="reviewTitle">撰寫評價</h2><button class="memberModalClose" id="reviewClose" type="button" aria-label="關閉">&times;</button></header><div class="memberModalBody"><form class="memberReviewForm" id="reviewForm" novalidate><p class="memberReviewProduct" id="reviewProductName">商品名稱</p><fieldset class="memberReviewFieldset"><legend class="memberReviewLabel">評分</legend><div class="memberRatingControl" id="reviewRatingGroup" role="radiogroup" aria-label="評分"><button type="button" class="memberRatingStar" data-review-rating="1" aria-label="1 分">★</button><button type="button" class="memberRatingStar" data-review-rating="2" aria-label="2 分">★</button><button type="button" class="memberRatingStar" data-review-rating="3" aria-label="3 分">★</button><button type="button" class="memberRatingStar" data-review-rating="4" aria-label="4 分">★</button><button type="button" class="memberRatingStar" data-review-rating="5" aria-label="5 分">★</button></div></fieldset><label class="memberReviewLabel" for="reviewContent">評論內容</label><textarea class="memberFormInput memberReviewTextarea" id="reviewContent" rows="4" placeholder="分享這次使用心得"></textarea><button class="memberAction memberActionPrimary memberActionBlock" id="submitReviewBtn" type="submit">送出評價</button></form></div></section></div>
</main>
